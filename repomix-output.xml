                                expenses={filteredLogExpenses} 
                                onDelete={(id) => setExpenses(prev => prev.filter(e => e.id !== id))}
                                soloCategory={soloCategory}
                                onToggleSolo={handleToggleSolo}
                                mutedCategories={mutedCategories}
